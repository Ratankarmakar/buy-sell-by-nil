//@version=6
// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © ratankarmakar

strategy("Buy sell by Nil", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     pyramiding=0,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=2,
     calc_on_every_tick=true)

// ==================== PATTERN SELECTION ====================
// Bullish Patterns
show_bull_engulf       = input.bool(true,  "Bullish Engulfing",        group="Bullish Patterns")
show_morning_star      = input.bool(true,  "Morning Star",             group="Bullish Patterns")
show_hammer            = input.bool(true,  "Hammer",                   group="Bullish Patterns")
show_inv_hammer        = input.bool(true,  "Inverted Hammer",          group="Bullish Patterns")
show_dragonfly_doji    = input.bool(true,  "Dragonfly Doji",           group="Bullish Patterns")
show_bull_harami       = input.bool(true,  "Bullish Harami",           group="Bullish Patterns")
show_piercing          = input.bool(true,  "Piercing Line",            group="Bullish Patterns")
show_tweezer_bottom    = input.bool(true,  "Tweezer Bottom",           group="Bullish Patterns")
show_3_soldiers        = input.bool(true,  "Three White Soldiers",     group="Bullish Patterns")
show_bull_kicker       = input.bool(true,  "Bullish Kicker",           group="Bullish Patterns")
show_bull_marubozu     = input.bool(true,  "Bullish Marubozu",         group="Bullish Patterns")
show_3_inside_up       = input.bool(true,  "Three Inside Up",          group="Bullish Patterns")
show_3_outside_up      = input.bool(true,  "Three Outside Up",         group="Bullish Patterns")
show_abandon_baby_bull = input.bool(true,  "Bullish Abandoned Baby",   group="Bullish Patterns")

// Bearish Patterns
show_bear_engulf       = input.bool(true,  "Bearish Engulfing",        group="Bearish Patterns")
show_evening_star      = input.bool(true,  "Evening Star",             group="Bearish Patterns")
show_hanging_man       = input.bool(true,  "Hanging Man",              group="Bearish Patterns")
show_shooting_star     = input.bool(true,  "Shooting Star",            group="Bearish Patterns")
show_gravestone_doji   = input.bool(true,  "Gravestone Doji",          group="Bearish Patterns")
show_bear_harami       = input.bool(true,  "Bearish Harami",           group="Bearish Patterns")
show_dark_cloud        = input.bool(true,  "Dark Cloud Cover",         group="Bearish Patterns")
show_tweezer_top       = input.bool(true,  "Tweezer Top",              group="Bearish Patterns")
show_3_crows           = input.bool(true,  "Three Black Crows",        group="Bearish Patterns")
show_bear_kicker       = input.bool(true,  "Bearish Kicker",           group="Bearish Patterns")
show_bear_marubozu     = input.bool(true,  "Bearish Marubozu",         group="Bearish Patterns")
show_3_inside_down     = input.bool(true,  "Three Inside Down",        group="Bearish Patterns")
show_3_outside_down    = input.bool(true,  "Three Outside Down",       group="Bearish Patterns")
show_abandon_baby_bear = input.bool(true,  "Bearish Abandoned Baby",   group="Bearish Patterns")

// ==================== FILTER SETTINGS ====================
use_trend_filter       = input.bool(true,  "Trend Filter",             group="Filters")
trend_period           = input.int(50,     "Trend MA Period",          group="Filters", minval=10)
use_volume_filter      = input.bool(false, "Volume Filter",            group="Filters")
vol_mult               = input.float(1.0,  "Volume Multiplier",        group="Filters", minval=0.1, step=0.1)
min_body_percent       = input.float(5.0,  "Min Body % of Range",      group="Filters", minval=0.0, maxval=50.0, step=1.0)

// ==================== RISK MANAGEMENT ====================
use_sl                 = input.bool(true,  "Enable Stop Loss",         group="Risk Management")
sl_atr_mult            = input.float(1.5,  "SL: ATR Multiplier",       group="Risk Management", minval=0.1, step=0.1)
use_tp                 = input.bool(true,  "Enable Take Profit",       group="Risk Management")
rr_ratio               = input.float(2.0,  "Risk:Reward Ratio",        group="Risk Management", minval=0.5, step=0.1)
atr_period             = input.int(14,     "ATR Period",               group="Risk Management", minval=1)

// ==================== CONFIRMATION ====================
req_confirm            = input.bool(false, "Require Next Candle Confirmation", group="Confirmation")

// ==================== ALERT SETTINGS ====================
enable_alerts          = input.bool(true,  "Enable Alerts",            group="Alert Settings")

// ==================== VISUAL SETTINGS ====================
show_signals           = input.bool(true,  "Show Signals",             group="Visual")
show_trend_bg          = input.bool(true,  "Show Trend Background",    group="Visual")
show_sl_tp_lines       = input.bool(true,  "Show SL/TP Lines",         group="Visual")
show_performance_table = input.bool(true,  "Show Performance Table",   group="Visual")

// ==================== HELPER CALCULATIONS ====================
// Technical indicators
atr_val = ta.atr(atr_period)
sma_trend = ta.sma(close, trend_period)
ema_trend = ta.ema(close, trend_period)
vol_sma = ta.sma(volume, 20)

// Trend conditions
use_ema = input.bool(false, "Use EMA instead of SMA", group="Filters")
trend_line = use_ema ? ema_trend : sma_trend
uptrend = close > trend_line
downtrend = close < trend_line

// Volume condition
volume_ok = not use_volume_filter or (volume > vol_sma * vol_mult)

// Candlestick calculations
body = math.abs(close - open)
upper_shadow = high - math.max(open, close)
lower_shadow = math.min(open, close) - low
total_range = high - low
body_pct = total_range > 0 ? body / total_range * 100 : 0.0
is_bull = close > open
is_bear = close < open
min_body_ok = body_pct >= min_body_percent

// ==================== BULLISH PATTERNS ====================
bull_engulf = show_bull_engulf and is_bull and is_bear[1] and open <= close[1] and close >= open[1] and body > body[1]

morning_star = show_morning_star and is_bear[2] and body[2] > total_range[2] * 0.4 and body[1] < total_range[1] * 0.3 and is_bull and close > (open[2] + close[2]) / 2

hammer = show_hammer and lower_shadow >= body * 2.0 and upper_shadow <= body * 0.5 and min_body_ok

inv_hammer = show_inv_hammer and upper_shadow >= body * 2.0 and lower_shadow <= body * 0.5 and min_body_ok

dragonfly_doji = show_dragonfly_doji and body_pct <= 5.0 and lower_shadow >= total_range * 0.6 and upper_shadow <= total_range * 0.1

bull_harami = show_bull_harami and is_bear[1] and is_bull and open > close[1] and close < open[1] and body < body[1]

piercing = show_piercing and is_bear[1] and is_bull and open < low[1] and close > (open[1] + close[1]) / 2 and close < open[1]

tweezer_bottom = show_tweezer_bottom and math.abs(low - low[1]) <= atr_val * 0.1 and is_bear[1] and is_bull

three_soldiers = show_3_soldiers and is_bull and is_bull[1] and is_bull[2] and close > close[1] and close[1] > close[2] and open > open[1] and open[1] > open[2] and body > total_range * 0.4 and body[1] > total_range[1] * 0.4 and body[2] > total_range[2] * 0.4

bull_kicker = show_bull_kicker and is_bear[1] and is_bull and open > open[1]

bull_marubozu = show_bull_marubozu and is_bull and upper_shadow <= atr_val * 0.05 and lower_shadow <= atr_val * 0.05 and body > total_range * 0.9

three_inside_up = show_3_inside_up and is_bear[2] and is_bull[1] and high[1] < open[2] and low[1] > close[2] and is_bull and close > high[1]

three_outside_up = show_3_outside_up and is_bear[2] and is_bull[1] and close[1] > open[2] and open[1] < close[2] and is_bull and close > high[1]

abandon_baby_bull = show_abandon_baby_bull and is_bear[2] and body[1] <= total_range[1] * 0.1 and low[1] < low[2] and low[1] < low and is_bull and open > high[1]

// ==================== BEARISH PATTERNS ====================
bear_engulf = show_bear_engulf and is_bear and is_bull[1] and open >= close[1] and close <= open[1] and body > body[1]

evening_star = show_evening_star and is_bull[2] and body[2] > total_range[2] * 0.4 and body[1] < total_range[1] * 0.3 and is_bear and close < (open[2] + close[2]) / 2

hanging_man = show_hanging_man and lower_shadow >= body * 2.0 and upper_shadow <= body * 0.5 and min_body_ok and (not use_trend_filter or uptrend)

shooting_star = show_shooting_star and upper_shadow >= body * 2.0 and lower_shadow <= body * 0.5 and min_body_ok

gravestone_doji = show_gravestone_doji and body_pct <= 5.0 and upper_shadow >= total_range * 0.6 and lower_shadow <= total_range * 0.1

bear_harami = show_bear_harami and is_bull[1] and is_bear and open < close[1] and close > open[1] and body < body[1]

dark_cloud = show_dark_cloud and is_bull[1] and is_bear and open > high[1] and close < (open[1] + close[1]) / 2 and close > open[1]

tweezer_top = show_tweezer_top and math.abs(high - high[1]) <= atr_val * 0.1 and is_bull[1] and is_bear

three_crows = show_3_crows and is_bear and is_bear[1] and is_bear[2] and close < close[1] and close[1] < close[2] and open < open[1] and open[1] < open[2] and body > total_range * 0.4 and body[1] > total_range[1] * 0.4 and body[2] > total_range[2] * 0.4

bear_kicker = show_bear_kicker and is_bull[1] and is_bear and open < open[1]

bear_marubozu = show_bear_marubozu and is_bear and upper_shadow <= atr_val * 0.05 and lower_shadow <= atr_val * 0.05 and body > total_range * 0.9

three_inside_down = show_3_inside_down and is_bull[2] and is_bear[1] and high[1] < close[2] and low[1] > open[2] and is_bear and close < low[1]

three_outside_down = show_3_outside_down and is_bull[2] and is_bear[1] and close[1] < open[2] and open[1] > close[2] and is_bear and close < low[1]

abandon_baby_bear = show_abandon_baby_bear and is_bull[2] and body[1] <= total_range[1] * 0.1 and high[1] > high[2] and high[1] > high and is_bear and open < low[1]

// ==================== SIGNAL GENERATION ====================
// Combine all bullish patterns
buy_raw = bull_engulf or morning_star or hammer or inv_hammer or dragonfly_doji or bull_harami or piercing or tweezer_bottom or three_soldiers or bull_kicker or bull_marubozu or three_inside_up or three_outside_up or abandon_baby_bull

// Combine all bearish patterns
sell_raw = bear_engulf or evening_star or hanging_man or shooting_star or gravestone_doji or bear_harami or dark_cloud or tweezer_top or three_crows or bear_kicker or bear_marubozu or three_inside_down or three_outside_down or abandon_baby_bear

// Apply filters
buy_filtered = buy_raw and volume_ok and (not use_trend_filter or uptrend)
sell_filtered = sell_raw and volume_ok and (not use_trend_filter or downtrend)

// Apply confirmation if requested
buy_signal = req_confirm ? (buy_filtered[1] and close > open) : buy_filtered
sell_signal = req_confirm ? (sell_filtered[1] and close < open) : sell_filtered

// ==================== ENTRY AND RISK MANAGEMENT ====================
// Calculate SL and TP distances
sl_dist = atr_val * sl_atr_mult
tp_dist = sl_dist * rr_ratio

// Entry conditions with position management
if buy_signal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    if use_sl
        strategy.exit("Long Exit", "Long", stop=close - sl_dist, limit=use_tp ? close + tp_dist : na)

if sell_signal and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    if use_sl
        strategy.exit("Short Exit", "Short", stop=close + sl_dist, limit=use_tp ? close - tp_dist : na)

// Reversal signals
if sell_signal and strategy.position_size > 0
    strategy.close("Long", comment="Reversal Short")
if buy_signal and strategy.position_size < 0
    strategy.close("Short", comment="Reversal Long")

// Emergency exit on opposite trend (optional)
use_emergency_exit = input.bool(false, "Emergency Exit on Trend Change", group="Risk Management")
if use_emergency_exit
    if strategy.position_size > 0 and downtrend
        strategy.close("Long", comment="Emergency Exit - Downtrend")
    if strategy.position_size < 0 and uptrend
        strategy.close("Short", comment="Emergency Exit - Uptrend")

// ==================== ALERTS ====================
// Create alert messages
if enable_alerts
    if buy_signal
        alert("Bullish candlestick pattern detected at " + str.tostring(close), alert.freq_once_per_bar_close)
    if sell_signal
        alert("Bearish candlestick pattern detected at " + str.tostring(close), alert.freq_once_per_bar_close)

// ==================== VISUAL ELEMENTS ====================
// Plot signals - using show_signals to control visibility
plotshape(show_signals ? buy_signal : false, style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.small, title="Buy Signal")
plotshape(show_signals ? sell_signal : false, style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, title="Sell Signal")

// Plot trend line
plot(use_trend_filter ? trend_line : na, color=color.new(color.orange, 30), linewidth=2, title="Trend MA")

// Trend background - using show_trend_bg to control visibility
bgcolor(show_trend_bg and use_trend_filter ? (uptrend ? color.new(color.green, 92) : color.new(color.red, 92)) : na, title="Trend Background")

// Plot SL/TP levels
plot(show_sl_tp_lines and strategy.position_size > 0 and use_sl ? strategy.position_avg_price - sl_dist : na, color=color.new(color.red, 20), style=plot.style_linebr, linewidth=1, title="Long SL")
plot(show_sl_tp_lines and strategy.position_size > 0 and use_tp ? strategy.position_avg_price + tp_dist : na, color=color.new(color.green, 20), style=plot.style_linebr, linewidth=1, title="Long TP")
plot(show_sl_tp_lines and strategy.position_size < 0 and use_sl ? strategy.position_avg_price + sl_dist : na, color=color.new(color.red, 20), style=plot.style_linebr, linewidth=1, title="Short SL")
plot(show_sl_tp_lines and strategy.position_size < 0 and use_tp ? strategy.position_avg_price - tp_dist : na, color=color.new(color.green, 20), style=plot.style_linebr, linewidth=1, title="Short TP")

// ==================== PERFORMANCE METRICS TABLE ====================
// Calculate performance metrics
var float totalTrades = 0.0
var float winningTrades = 0.0
var float losingTrades = 0.0
var float totalPnl = 0.0

if strategy.closedtrades > totalTrades
    totalTrades := strategy.closedtrades
    winningTrades := 0.0
    losingTrades := 0.0
    totalPnl := 0.0
    
    for i = 0 to strategy.closedtrades - 1
        tradePnl = strategy.closedtrades.profit(i)
        totalPnl := totalPnl + tradePnl
        if tradePnl > 0
            winningTrades := winningTrades + 1
        if tradePnl <= 0
            losingTrades := losingTrades + 1

winRate = totalTrades > 0 ? (winningTrades / totalTrades) * 100 : 0.0
avgTrade = totalTrades > 0 ? totalPnl / totalTrades : 0.0
profitFactor = strategy.grossloss != 0 ? strategy.grossprofit / math.abs(strategy.grossloss) : strategy.grossprofit > 0 ? 999 : 0

// Display performance table - only on last bar and when the chart is fully loaded
isLastBar = barstate.islast and not barstate.isrealtime

if show_performance_table and isLastBar
    var table performanceTable = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 90), border_width=1, border_color=color.gray)
    
    table.cell(performanceTable, 0, 0, "Metric", text_color=color.white, bgcolor=color.navy)
    table.cell(performanceTable, 1, 0, "Value", text_color=color.white, bgcolor=color.navy)
    
    table.cell(performanceTable, 0, 1, "Total Trades", text_color=color.white)
    table.cell(performanceTable, 1, 1, str.tostring(totalTrades, "#"), text_color=color.yellow)
    
    table.cell(performanceTable, 0, 2, "Win Rate", text_color=color.white)
    table.cell(performanceTable, 1, 2, str.tostring(winRate, "#.##") + "%", text_color=color.lime)
    
    table.cell(performanceTable, 0, 3, "Avg Trade", text_color=color.white)
    table.cell(performanceTable, 1, 3, str.tostring(avgTrade, "#.##"), text_color=avgTrade > 0 ? color.lime : color.red)
    
    table.cell(performanceTable, 0, 4, "Net Profit", text_color=color.white)
    table.cell(performanceTable, 1, 4, str.tostring(strategy.netprofit, "#.##"), text_color=strategy.netprofit > 0 ? color.lime : color.red)
    
    table.cell(performanceTable, 0, 5, "Max DD", text_color=color.white)
    table.cell(performanceTable, 1, 5, str.tostring(strategy.max_drawdown, "#.##"), text_color=color.orange)
    
    table.cell(performanceTable, 0, 6, "Profit Factor", text_color=color.white)
    pf_text = profitFactor > 999 ? "8" : str.tostring(profitFactor, "#.##")
    table.cell(performanceTable, 1, 6, pf_text, text_color=color.aqua)